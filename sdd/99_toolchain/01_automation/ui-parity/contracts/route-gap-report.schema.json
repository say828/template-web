{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UIParityRouteGapReport",
  "type": "object",
  "required": [
    "generated_at",
    "service",
    "screens_path",
    "routes_path",
    "summary",
    "screens"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "service": {
      "type": "string"
    },
    "screens_path": {
      "type": "string"
    },
    "routes_path": {
      "type": "string"
    },
    "summary": {
      "type": "object",
      "required": ["total", "direct", "shared", "stateful", "missing"],
      "properties": {
        "total": { "type": "number" },
        "direct": { "type": "number" },
        "shared": { "type": "number" },
        "stateful": { "type": "number" },
        "missing": { "type": "number" },
        "coverage_ratio": { "type": "number" },
        "explicit_bindings": { "type": "number" },
        "strong_evidence": { "type": "number" },
        "medium_evidence": { "type": "number" },
        "weak_evidence": { "type": "number" },
        "with_notes": { "type": "number" },
        "with_tags": { "type": "number" },
        "duplicate_route_groups": { "type": "number" }
      }
    },
    "duplicate_route_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "screen_ids"],
        "properties": {
          "route": { "type": "string" },
          "screen_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "route": { "type": ["string", "null"] },
          "binding": { "type": "string" },
          "binding_source": { "type": "string" },
          "coverage_state": { "type": "string" },
          "evidence_level": { "type": "string" },
          "route_defined": { "type": "boolean" },
          "has_notes": { "type": "boolean" },
          "has_tags": { "type": "boolean" },
          "duplicate_route_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["direct", "shared", "stateful", "missing"]
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
